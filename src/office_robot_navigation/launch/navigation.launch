<launch>
  <!-- Arguments -->
  <param name="/use_sim_time" value="true"/>
  <arg name="model" default="$(env TURTLEBOT3_MODEL)" doc="model type [burger, waffle, waffle_pi]"/>
  <arg name="map_file" default="$(find office_robot_navigation)/maps/office_map.yaml"/>
  <arg name="open_rviz" default="true"/>
  <arg name="move_forward_only" default="false"/>

  <!-- Gazebo world -->
<include file="$(find gazebo_ros)/launch/empty_world.launch">
  <arg name="world_name" value="$(find office_robot_sim)/worlds/office.world"/>
  <arg name="paused" value="false"/>
  <arg name="use_sim_time" value="true"/>
  <arg name="gui" value="true"/>
  <arg name="headless" value="false"/>
  <arg name="debug" value="false"/>
</include>
  <param name="robot_description" command="$(find xacro)/xacro '$(find turtlebot3_description)/urdf/turtlebot3_waffle_pi.urdf.xacro'"/>
  <node pkg="gazebo_ros" type="spawn_model" name="spawn_urdf" args="-urdf -model turtlebot3_waffle_pi -x -3 -y -4 -z 0 -param robot_description"/>
  <node pkg="robot_state_publisher" type="robot_state_publisher" name="robot_state_publisher">
  <param name="publish_frequency" value="50.0"/>
  <param name="use_tf_static" value="true"/>
</node>

  <!-- Map server -->
  <node pkg="map_server" name="map_server" type="map_server" args="$(arg map_file)"/>

  <!-- AMCL -->
  <include file="$(find turtlebot3_navigation)/launch/amcl.launch">
    <arg name="initial_pose_x" value="-3.0"/>
    <arg name="initial_pose_y" value="-4.0"/>
    <arg name="initial_pose_a" value="0.0"/>
  </include>
  
  <!-- move_base (load turtlebot3 defaults first, then override with our params) -->
  <include file="$(find turtlebot3_navigation)/launch/move_base.launch">
    <arg name="model" value="$(arg model)" />
    <arg name="move_forward_only" value="$(arg move_forward_only)"/>
  </include>
  <!-- ====== CUSTOM PARAM OVERRIDES (must come after the include) ====== -->
  <rosparam ns="/move_base/global_costmap" file="$(find office_robot_navigation)/params/costmap_common_params_waffle_pi.yaml"/>
  <rosparam ns="/move_base/local_costmap"  file="$(find office_robot_navigation)/params/costmap_common_params_waffle_pi.yaml"/>
  <!-- 以下三个 YAML 自带顶层 key（local_costmap:/global_costmap:/DWAPlannerROS:），ns 必须用 /move_base -->
  <rosparam ns="/move_base" file="$(find office_robot_navigation)/params/local_costmap_params.yaml"/>
  <rosparam ns="/move_base" file="$(find office_robot_navigation)/params/global_costmap_params.yaml"/>
  <rosparam ns="/move_base" file="$(find office_robot_navigation)/params/move_base_params.yaml"/>
  <rosparam ns="/move_base" file="$(find office_robot_navigation)/params/dwa_local_planner_params_waffle_pi.yaml"/>

  <!-- ====== 全局规划器 navfn 参数（长距离回家依赖这个） ====== -->
  <rosparam ns="/move_base/NavfnROS">
    allow_unknown: true
    default_tolerance: 0.5
    use_grid_path: true
    use_dijkstra: false
  </rosparam>
  <rosparam ns="/move_base/GlobalPlanner">
    allow_unknown: true
    default_tolerance: 0.5
    use_grid_path: true
    use_dijkstra: false
  </rosparam>

  <!-- rviz -->
  <group if="$(arg open_rviz)"> 
    <node pkg="rviz" type="rviz" name="rviz" required="true"
          args="-d $(find turtlebot3_navigation)/rviz/turtlebot3_navigation.rviz"/>
  </group>
</launch>
